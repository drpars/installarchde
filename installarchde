  )

  sel=$(dialog --backtitle "$apptitle" --title "Dotfiles :" --default-item "${nextitem}" --cancel-button "Back" --menu "" 0 0 0 "${options[@]}" 3>&1 1>&2 2>&3)
  if [ "$?" = "0" ]; then
    case ${sel} in
    "Copy neovim dotfiles")
      if (confirm "Do you want to copy nvim config ? \n "); then
        clear
        git clone https://github.com/drpars/nvim.git /home/$(whoami)/.config/nvim
        message "Nvim config files are copied. \n "

        if (confirm "Also do you want to copy nvim for root \n "); then
          if [ ! -d /root/.config/nvim ]; then
            sudo mkdir -p /root/.config/nvim
          fi
          sudo ln -sf /home/$(whoami)/.config/nvim/* /root/.config/nvim
          message "Nvim config files are copied for root. \n "
        fi
      fi
      nextitem="Copy ohmyzsh dotfiles"
      ;;
    "Copy ohmyzsh dotfiles")
      if (confirm "Do you want to copy dotfiles ? \n "); then
        if [ ! -d hypr-dot ]; then
          clear
          git clone https://github.com/drpars/hypr-dot.git
        fi
        if [ -f /usr/bin/zsh ]; then
          message "Oh my zsh will want to replace bash. \nTo continue, \nyou must type exit."
          if [ ! -d /home/$(whoami)/.ohmyzsh ]; then
            clear
            # for home user
            sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
            git clone https://github.com/zsh-users/zsh-syntax-highlighting.git ${ZSH_CUSTOM:-~/.oh-my-zsh/custom}/plugins/zsh-syntax-highlighting
            git clone https://github.com/zsh-users/zsh-autosuggestions ${ZSH_CUSTOM:-~/.oh-my-zsh/custom}/plugins/zsh-autosuggestions
          else
            message "Oh my zsh is already installed for /home/$(whoami)."
          fi
          # for root user
          if (confirm "Do you want to install also for root ? \n"); then
            if [ ! -d /root/.ohmyzsh ]; then
              clear
              sudo sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
              sudo git clone https://github.com/zsh-users/zsh-syntax-highlighting.git /root/.oh-my-zsh/custom/plugins/zsh-syntax-highlighting
              sudo git clone https://github.com/zsh-users/zsh-autosuggestions /root/.oh-my-zsh/custom/plugins/zsh-autosuggestions
            else
              message "Oh my zsh is already installed for root."
            fi
          fi
          pressanykey
        else
          message "zsh not detected !!"
        fi
        if [ -d /root/.ohmyzsh ]; then
          if [ -f /root/.zshrc ]; then
            sudo mv /root/.zshrc $backupdir/.zshrc-root
            sudo ln -sr $clonedir/.zshrc /root/
          fi
        fi
        message "Config files are copied for home user."
      fi
      nextitem="Copy fonts"
      ;;
    "Copy fonts")
      if (confirm "Do you want to copy fonts ? \n "); then
        if [ ! -d hypr-dot ]; then
          clear
          git clone https://github.com/drpars/hypr-dot.git
        fi
        message "/home/$(whoami)/.fonts will back up to $backupdir"
        if [ ! -d /home/$(whoami)/.fonts ]; then
          ln -sr $clonedir/.fonts /home/$(whoami)
        else
          mv /home/$(whoami)/.fonts $backupdir
        fi
      fi
      nextitem="Copy sddm themes"
      ;;
    "Copy sddm themes")
      if (confirm "Do you want to copy themes for sddm ?"); then
        if [ ! -d hypr-dot ]; then
          clear
          git clone https://github.com/drpars/hypr-dot.git
        fi
        clear
        if [ -f /usr/bin/sddm ]; then
          sddm_conf_dir=/etc/sddm.conf.d
          if [ ! -d "$sddm_conf_dir" ]; then
            printf "$sddm_conf_dir not found, creating...\n"
            sudo mkdir "$sddm_conf_dir"
          fi
          echo -e "[Theme]\nCurrent=sugar-candy" | sudo tee "$sddm_conf_dir/10-theme.conf" >/dev/null
          sudo cp $clonedir/sddm/sddm.conf "$sddm_conf_dir/"
          sugar_candy_dir=/usr/share/sddm/themes/sugar-candy
          if [ ! -d "$sugar_candy_dir" ]; then
            printf "$sugar_candy_dir not found, creating...\n"
            sudo tar -xzvf $clonedir/sddm/sugar-candy/sugar-candy.tar.gz -C /usr/share/sddm/themes/
            sudo cp $clonedir/sddm/sugar-candy/theme.conf "$sugar_candy_dir/"
            sudo cp $clonedir/sddm/sugar-candy/background.jpg "$sugar_candy_dir/Backgrounds/"
          fi
        else
          message "Sddm not installed. \nFirstly install sddm!"
        fi
      fi
      nextitem="Copy wallpaper"
      ;;
    "Copy wallpaper")
      if (confirm "Do do you want to copy wallpapers to $wallpaperdir ? \n "); then
        if [ -d $wallpaperdir/Wallpaper ]; then
          message "$wallpaperdir/Wallpaper is exist... \nNothing copied!"
        else
          clear
          git clone https://github.com/drpars/Wallpaper.git $wallpaperdir
          pressanykey
        fi
      fi
      nextitem="Copy Hyprland dotfiles"
      ;;
    "Copy Hyprland dotfiles")
      if (confirm "Do do you want to copy hyprland dotfiles ? \n "); then
        if [ ! -d hypr-dot ]; then
          clear
          git clone https://github.com/drpars/hypr-dot.git
        fi
        clear
        mkdir -p $backupdir/old
        mkdir -p $clonedir
        if diff -r hypr-dot $clonedir; then
          message "$clonedir is up to date."
        else
          # different files
          if (confirm "Dotfiles doesn't exist or out of date. \nDo you want to backup existing dotfiles, if there are ? \n "); then
            mv $clonedir $backupdir/old
            message "Old files are backed up to $backupdir/old."
            cp -r hypr-dot /home/$(whoami)/.dotfiles/
          else
            rm -rf $clonedir
            cp -r hypr-dot /home/$(whoami)/.dotfiles/
          fi
        fi
        # backuo
        for sel in $configfiles; do
          if [ -d /home/$(whoami)/.config/$sel ]; then
            mv /home/$(whoami)/.config/$sel $backupdir
          elif [ -L /home/$(whoami)/.config/$sel ]; then
            rm /home/$(whoami)/.config/$sel
          fi
        done
        # ~/.config files
        ln -sr $clonedir/config/* /home/$(whoami)/.config
        # ~ files
        for sel in $homefiles; do
          if [ ! -f /home/$(whoami)/$sel ]; then
            ln -sr $clonedir/$sel /home/$(whoami)
          else
            mv /home/$(whoami)/$sel $backupdir
            ln -sr $clonedir/$sel /home/$(whoami)
          fi
        done
      fi
      nextitem="Authorize Hyprland dotfiles"
      ;;
    "Authorize Hyprland dotfiles")
      if (confirm "Do you want to authorize $clonedir with github token key?"); then
        username=$(dialog --backtitle "$apptitle" --title "Authorize hypr-dot repo" --inputbox "Enter your github user name :" 0 0 3>&1 1>&2 2>&3)
        token=$(dialog --backtitle "$apptitle" --title "Authorize hypr-dot repo" --inputbox "Enter your github token key :" 0 0 3>&1 1>&2 2>&3)
        clear
        cd $clonedir
        git remote set-url origin https://$username:$token@github.com/$username/hypr-dot.git
        cd ..
      fi
      nextitem="Authorize Hyprland dotfiles"
      ;;
    "Remove neovim dotfiles")
      if (confirm "Do you want to remove nvim ? \n "); then
        clear
        rm -rf ~/.config/nvim
        rm -rf ~/.local/share/nvim
        rm -rf ~/.cache/nvim
        message "Neovim configs are completely removed. \n "
      fi
      nextitem="Remove neovim dotfiles"
      ;;
    esac
    dotfilesmenu "${nextitem}"
  fi
}

shutdownmenu() {
  options=(
    "Reboot" ""
    "Shutdown" ""
  )
  sel=$(dialog --backtitle "$apptitle" --title "Shutdown :" --cancel-button "Back" --menu "" 0 0 0 "${options[@]}" 3>&1 1>&2 2>&3)
  if [ "$?" = 0 ]; then
    case $sel in
    "Reboot")
      if (confirm "Reboot now ?" --defaultno); then
        reboot
      fi
      ;;
    "Shutdown")
      if (confirm "Shutdown now ?" --defaultno); then
        poweroff
      fi
      ;;
    esac
  fi
}

