driversmenu() {
  if [ "${1}" = "" ]; then
    nextitem="."
  else
    nextitem=${1}
  fi

  options=(
    "Amd" ""
    "Nvidia" ""
    "Nvidia VA-API" "nvidia-vaapi-driver"
    "Asus" ""
    "Sound" ""
    "Mkinitcpio firmware" "(AUR)"
  )
  sel=$(dialog --backtitle "$apptitle" --title "Drivers :" --default-item "${nextitem}" --cancel-button "Back" --menu "" 0 0 0 "${options[@]}" 3>&1 1>&2 2>&3)
  if [ "$?" = 0 ]; then
    case ${sel} in
    "Amd")
      amddriver
      nextitem="Nvidia"
      ;;
    "Nvidia")
      nvidiadriver
      nextitem="Nvidia VA-API"
      ;;
    "Nvidia VA-API")
      options=(
        "meson" "" on
        "gst-plugins-bad" "" on
        "ffnvcodec-headers" "" on
      )

      sel=$(dialog --backtitle "$apptitle" --title "NVIDIA VA-API dependencies :" --cancel-button "Back" --checklist "" 0 0 0 "${options[@]}" 3>&1 1>&2 2>&3)

      if [ "$?" = 0 ]; then
        for item in $sel; do
          case $item in
          # "") aurpkg="$aurpkg $(echo $item | sed 's/"//g')" ;;
          *) pkg="$pkg $(echo $item | sed 's/"//g')" ;;
          esac
        done
        instpkg "$pkg" "$aurpkg"
        if (pacman -Qs ffnvcodec-headers); then
          clear
          git clone https://github.com/elFarto/nvidia-vaapi-driver.git
          cd nvidia-vaapi-driver
          meson setup build
          meson install -C build
          cd ..
          rm -rf nvidia-vaapi-driver
          echo "nvidia-vaapi-driver is successfully installed"
          pressanykey
        fi
      fi
      nextitem="Asus"
      ;;
    "Asus")
      asusdriver
      nextitem="Sound"
      ;;
    "Sound")
      sounddriver
      nextitem="Mkinitcpio firmware"
      ;;
    "Mkinitcpio firmware")
      if (confirm "Do you want to install firmware ? \n "); then
        clear
        instpkg "" mkinitcpio-firmware
        pressanykey
      fi
      nextitem="Mkinitcpio firmware"
      ;;
    esac
    driversmenu "${nextitem}"
  fi
}

amddriver() {
  options=(
    "mesa" "" on
    "lib32-mesa" "" on
    "xf86-video-amdgpu" "" on
    "vulkan-radeon" "" on
    "lib32-vulkan-radeon" "" on
    "libva-mesa-driver" "" on
    "lib32-libva-mesa-driver" "" on
    "mesa-vdpau" "" on
    "lib32-mesa-vdpau" "" on
  )
  sel=$(dialog --backtitle "$apptitle" --title "Amd :" --cancel-button "Back" --checklist "" 0 0 0 "${options[@]}" 3>&1 1>&2 2>&3)
  if [ "$?" = 0 ]; then
    for item in $sel; do
      case $item in
      # "") aurpkg="$aurpkg $(echo $item | sed 's/"//g')" ;;
      *) pkg="$pkg $(echo $item | sed 's/"//g')" ;;
      esac
    done
    instpkg "$pkg" "$aurpkg"
    if (pacman -Qs mesa); then
      if (confirm "Do you want to apply necessary modules ? \n "); then
        clear
        amdmodule="amdgpu radeon"
        if (gpumodel "amd"); then
          gpumodule="$amdmodule"
        else
          gpumodule=""
        fi
        # /etc/mkinitcpio.conf
        presentmkinitcpiomodules=$(cat /etc/mkinitcpio.conf | grep 'MODULES' | awk -F\) '{print $1}' | tr -d 'MODULES=(')
        if [[ $presentmkinitcpiomodules = "" ]]; then
          sudo sed -i "s/MODULES=()/MODULES=(${gpumodule})/g" /etc/mkinitcpio.conf
          sudo mkinitcpio -P
        else
          if (echo $presentmkinitcpiomodules | grep "$gpumodule" >/dev/null); then
            clear
            echo "$gpumodule -  Related modules already exist..."
            pressanykey
          else
            newmkinitcpiomodules="${presentmkinitcpiomodules} ${gpumodule}"
            sudo sed -i "s/MODULES=(${presentmkinitcpiomodules})/MODULES=(${newmkinitcpiomodules})/g" /etc/mkinitcpio.conf
            sudo mkinitcpio -P
          fi
        fi
      fi
    fi
  fi
}

nvidiadriver() {
  options=(
    "nvidia" "" off
    "nvidia-lts" "" off
    "nvidia-dkms" "" on
    "nvidia-open" "" off
    "nvidia-open-dkms" "" off
    "nvidia-utils" "" on
    "lib32-nvidia-utils" "" on
    "nvidia-settings" "" on
    "egl-wayland" "" on
    "libva-nvidia-driver" "" on
  )
  sel=$(dialog --backtitle "$apptitle" --title "Nvidia :" --cancel-button "Back" --checklist "" 0 0 0 "${options[@]}" 3>&1 1>&2 2>&3)
  if [ "$?" = 0 ]; then
    for item in $sel; do
      case $item in
      # "") aurpkg="$aurpkg $(echo $item | sed 's/"//g')" ;;
      *) pkg="$pkg $(echo $item | sed 's/"//g')" ;;
      esac
    done
    instpkg "$pkg" "$aurpkg"
    if (pacman -Qs nvidia); then
      if (confirm "Do you want to apply necessary modules ? \n "); then
        clear
        nvidiamodule="nvidia nvidia_modeset nvidia_uvm nvidia_drm"
        nvidiakernelmodule="modeset=1"
        if (gpumodel "nvidia"); then
          gpumodule="$nvidiamodule"
          gpukernel="$nvidiakernelmodule"
        else
          gpumodule=""
          gpukernel=""
        fi
        # /etc/mkinitcpio.conf - MODULES
        presentmkinitcpiomodules=$(cat /etc/mkinitcpio.conf | grep 'MODULES' | awk -F\) '{print $1}' | tr -d 'MODULES=(')
        if [[ $presentmkinitcpiomodules = "" ]]; then
          sudo sed -i "s/MODULES=()/MODULES=(${gpumodule})/g" /etc/mkinitcpio.conf
          sudo mkinitcpio -P
        else
          if (echo $presentmkinitcpiomodules | grep "$gpumodule" >/dev/null); then
            clear
            echo "$gpumodule -  Related modules already exist..."
            pressanykey
          else
            newmkinitcpiomodules="${presentmkinitcpiomodules} ${gpumodule}"
            sudo sed -i "s/MODULES=(${presentmkinitcpiomodules})/MODULES=(${newmkinitcpiomodules})/g" /etc/mkinitcpio.conf
            sudo mkinitcpio -P
          fi
        fi
        # /etc/modprobe.d/nvidia.conf
        clear
        if [[ ! -f /etc/modprobe.d/nvidia.conf ]]; then
          echo "options nvidia_drm modeset=1 fbdev=1" | sudo tee /etc/modprobe.d/nvidia.conf >/dev/null
          sudo mkinitcpio -P
          pressanykey
        fi
        # kernel mod - /etc/kernel/cmdline
        presentkernelcmdline=$(cat /etc/kernel/cmdline)
        if [ -f /etc/kernel/cmdline ]; then
          if [[ $presentkernelcmdline != "" ]]; then
            if (echo $presentkernelcmdline | grep "$gpukernel" >/dev/null); then
              clear
              echo "$gpukernel -  Related modules already exist..."
              pressanykey
            else
              newkernelcmdline="${presentkernelcmdline} ${gpukernel}"
              echo $newkernelcmdline | sudo tee /etc/kernel/cmdline >/dev/null
              sudo mkinitcpio -P
            fi
          fi
        fi
      fi
    fi
  fi
}

asusdriver() {
  isg14repo=$(cat /etc/pacman.conf | grep -i "[g14]" >/dev/null)
  if ($isg14repo); then
    options=(
      "asusctl" "" on
      "supergfxctl" "" on
      "rog-control-center" "" on
      "brightnessctl" "" on
    )
  else
    options=(
      "asusctl" "(AUR)" on
      "supergfxctl" "(AUR)" on
      "rog-control-center" "(AUR)" on
      "brightnessctl" "" on
    )
  fi
  sel=$(dialog --backtitle "$apptitle" --title "Asus :" --cancel-button "Back" --checklist "" 0 0 0 "${options[@]}" 3>&1 1>&2 2>&3)
  if [ "$?" = 0 ]; then
    if ($isg14repo); then
      for item in $sel; do
        case $item in
        *) pkg="$pkg $(echo $item | sed 's/"//g')" ;;
        esac
      done
    else
      for item in $sel; do
        case $item in
        "asusctl") aurpkg="$aurpkg $(echo $item | sed 's/"//g')" ;;
        "supergfxctl") aurpkg="$aurpkg $(echo $item | sed 's/"//g')" ;;
        "rog-control-center") aurpkg="$aurpkg $(echo $item | sed 's/"//g')" ;;
        *) pkg="$pkg $(echo $item | sed 's/"//g')" ;;
        esac
      done
    fi
    instpkg "$pkg" "$aurpkg"
  fi
}

