configmenu() {
  if [ "${1}" = "" ]; then
    nextitem="."
  else
    nextitem=${1}
  fi

  options=(
    "Dotfiles" ""
    "Swap file settings" "systemd-boot kernel module"
    "Network settings" "For sharing"
  )

  sel=$(dialog --backtitle "$apptitle" --title "Confg Menu" --default-item "${nextitem}" --cancel-button "Back" --menu "" 0 0 0 "${options[@]}" 3>&1 1>&2 2>&3)
  if [ "$?" = "0" ]; then
    case ${sel} in
    "Dotfiles")
      dotfilesmenu
      nextitem="Swap file settings"
      ;;
    "Swap file settings")
      if (confirm "Do you want to apply kernel module for hibernation ? \nOnly for systemd-boot loader!!! \n "); then
        # /etc/kernel/cmdline
        presentkernelcmdline=$(cat /etc/kernel/cmdline)
        swapfileuuid=$(findmnt -no UUID -T /swapfile)
        swapfileoffset=$(sudo filefrag -v /swapfile | awk '$1=="0:" {print substr($4, 1, length($4)-2)}')
        if (echo $presentkernelcmdline | grep "$swapfileuuid"); then
          clear
          message "Kernel modules for hibernation already exist... \nCheck /etc/kernel/cmdline"
        else
          newkernelcmdline="${presentkernelcmdline} resume=UUID=$swapfileuuid resume_offset=$swapfileoffset"
          echo $newkernelcmdline | sudo tee /etc/kernel/cmdline >/dev/null
          clear
          sudo mkinitcpio -P
        fi
        # /etc/mkinitcpio.conf - HOOKS
        presentmkinitcpiohooks=$(cat /etc/mkinitcpio.conf | grep 'HOOKS' | awk -F\) '{print $1}' | tr -d 'HOOKS=(')
        swapfilehook="resume"
        if (echo $presentmkinitcpiohooks | grep "$swapfilehook" >/dev/null); then
          # sleep 1
          clear
          message "$swapfilehook -  Related modules already exist in HOOKS... \nCheck /etc/mkinitcpio.conf "
        else
          clear
          sudo sed -i -e 's/fsck/resume fsck/g' /etc/mkinitcpio.conf
          sudo mkinitcpio -P
          pressanykey
        fi
      else
        message "aldsakljhdkahsdkj"
      fi
      nextitem="Network settings"
      ;;
    "Network settings")
      options=(
        "samba" "" on
        "avahi" "" on
      )
      sel=$(dialog --backtitle "$apptitle" --title "Network :" --cancel-button "Back" --checklist "" 0 0 0 "${options[@]}" 3>&1 1>&2 2>&3)
      if [ "$?" = "0" ]; then
        if (pacman -Qs samba); then
          clear
          printf "%s\n" \
            "[global]" \
            "workgroup = WORKGROUP" \
            "usershare path = /var/lib/samba/usershares" \
            "usershare max shares = 100" \
            "usershare allow guests = yes" \
            "usershare owner only = yes" \
            "server string = Samba Server" \
            "client min protocol = CORE" \
            "server min protocol = CORE" \
            "; server max protocol = SMB3" \
            "server role = standalone server" \
            "log file = /var/log/samba/%m.log" \
            "logging = file" \
            "max log size = 1000" | sudo tee /etc/samba/smb.conf >/dev/null
          sleep 2
          serviceenable smb
          serviceenable nmb
          sudo systemctl start smb.service nmb.service
          sudo mkdir /var/lib/samba/usershares
          sudo groupadd -r sambashare
          sudo chown root:sambashare /var/lib/samba/usershares
          sudo chmod 1770 /var/lib/samba/usershares
          sudo gpasswd sambashare -a $(whoami)
          sudo smbpasswd -a $(whoami)
          serviceenable avahi-daemon.service
        fi
      fi
      nextitem="Network settings"
      ;;
    esac
    configmenu "${nextitem}"
  fi
}

dotfilesmenu() {
  backupdir=/home/$(whoami)/.dotfiles/backup
  clonedir=/home/$(whoami)/.dotfiles/hypr-dot
  configfiles="$(ls $clonedir/config)"
  wallpaperdir=$(xdg-user-dir PICTURES)
  homefiles="
          .gitconfig
          .gtkrc-2.0
          .zshrc
        "

  if [ "${1}" = "" ]; then
    nextitem="."
  else
    nextitem=${1}
  fi

  options=(
    "Copy neovim dotfiles" ""
    "Copy ohmyzsh dotfiles" ""
    "Copy fonts" ""
    "Copy sddm themes" ""
    "Copy wallpaper" ""
    "Copy Hyprland dotfiles" ""
