#!/bin/bash

apptitle="Arch Linux DE & Apps Installation"

mainmenu() {
  if [ "${1}" = "" ]; then
    nextitem="."
  else
    nextitem=${1}
  fi

  options=(
    "Update" ""
    "Install" ""
    "Config" ""
    "Shutdown" ""
  )

  sel=$(dialog --backtitle "$apptitle" --title "Main Menu" --default-item "${nextitem}" --cancel-button "Exit" --menu "" 0 0 0 "${options[@]}" 3>&1 1>&2 2>&3)

  if [ "$?" = "0" ]; then
    case ${sel} in
    "Update")
      updatemenu
      nextitem="Install"
      ;;
    "Install")
      installmenu
      nextitem="Config"
      ;;
    "Config")
      configmenu
      nextitem="Shutdown"
      ;;
    "Shutdown")
      shutdownmenu
      nextitem="Shutdown"
      ;;
    esac
    mainmenu "${nextitem}"
  else
    clear
  fi
}

resetvalue() {
  for arg
do
  unset ${arg}
done
}

cpumodel() {
  cat /proc/cpuinfo | awk '/model name/' | uniq | grep -i "$1" >/dev/null
}

gpumodel() {
  lspci | grep -E "(VGA|3D)" | awk '/"$1"/' >/dev/null
}

confirm() {
  dialog --backtitle "$apptitle" $2 --yesno "$1" 0 0
}

message() {
  dialog --backtitle "$apptitle" $2 --msgbox "$1" 0 0
}

pressanykey() {
  read -n1 -p "Press any key to continue."
}

instpkg() {
  if [ ! "$1" = "" ]; then
    clear
    echo "# sudo pacman -S --needed $1"
    sudo pacman -S --needed $1
    pressanykey
  fi
  if [ ! "$2" = "" ]; then
    if [ -f /usr/bin/yay ]; then
      clear
      echo "# sudo -u $(whoami) yay -S --needed $2"
      sudo -u $(whoami) yay -S --needed $2
      pressanykey
    else
      if [ -f /usr/bin/paru ]; then
        clear
        echo "# sudo -u $(whoami) paru -S --needed $2"
        sudo -u $(whoami) paru -S --needed $2
        pressanykey
      else
        echo "To install AUR packages, you need to install an aurhelper in Upadte menu !"
      fi
    fi
  fi
  resetvalue pkg aurpkg
}

choosepkg() {
  if [ "$2" = "" ]; then
    title=$1
  else
    title=$2
  fi
  options=()
  items=$(pacman -Ssq $1)
  for item in $items; do
    options+=("$item" "" off)
  done
  sel=$(dialog --backtitle "$apptitle" --title "$title" --cancel-button "Back" --checklist "" 0 0 0 "${options[@]}" 3>&1 1>&2 2>&3)
  if [ ! "$?" = "0" ]; then
    return 1
  fi
  for itm in $sel; do
    pkg="$pkg $(echo $itm | sed 's/"//g')"
  done
  instpkg "$pkg" "$aurpkg"
  return 0
}

serviceenable() {
  if [ "$2" = "" ]; then
    displayname="$1"
  else
    displayname="$2 ($1)"
  fi
  if (confirm "Start $displayname service at boot ?\n\nsystemctl enable $1"); then
    clear
    echo "sudo systemctl enable $1"
    sudo systemctl enable $1
    pressanykey
  fi
}

servicserviceedisable() {
